# Required secrets
# App auth secret.
JWT_SECRET=QQQQQQQQQQQQQQQQQQQQQQQQQQQQQQQQQQQQ
# ONLYOFFICE signing secret (used by both backend and onlyoffice services).
ONLYOFFICE_JWT_SECRET=QQQQQQQQQQQQQQQQQQQQQQQQQQ
ONLYOFFICE_SECURE_LINK_SECRET=QQQQQQQQQQQQQQQQQQQQQQQQQQQQQQ
# Optional but recommended
BOOTSTRAP_ADMIN_TOKEN=QQQQQQQQQQQQQQQQQQQQQQQQQQQQQQQQ
TOTP_ISSUER=Canary
# Public app URLs
CANARY_PUBLIC_URL=http://localhost:8000
ONLYOFFICE_DS_PUBLIC_URL=http://localhost:18080
CANARY_CALDAV_PUBLIC_URL=http://localhost:5232
# ONLYOFFICE backend-side routing tweaks (leave blank unless needed)
ONLYOFFICE_APP_URL_INTERNAL=
ONLYOFFICE_PREFER_IPV4_FOR_DS=
ONLYOFFICE_DOCUMENT_URL=
RADICALE_INTERNAL_URL=http://radicale:5232
# Published ports (IP:HOST:CONTAINER)
RADICALE_PORT_PUBLISH=0.0.0.0:5232:5232
ONLYOFFICE_PORT_PUBLISH=0.0.0.0:18080:80
FRONTEND_PORT_PUBLISH=0.0.0.0:8080:80
FRONTEND_DEV_PORT_PUBLISH=0.0.0.0:5173:5173
# Frontend build/runtime options
VITE_API_BASE=
VITE_ONLYOFFICE_URL=/office-ds
VITE_ONLYOFFICE_DIRECT_PORT=
VITE_ONLYOFFICE_DIRECT_URL=
# Microsoft Graph (optional — New > E-mail → Outlook draft in user mailbox; application permissions + admin consent)
# Also used by:
#   POST /api/outlook-plugin/ensure-master-category — seed Outlook master category list
#   POST /api/outlook-plugin/graph-tag-category — PATCH message categories when the add-in’s Office.js path fails
# Grant in Entra ID (application) at minimum what you use for drafts, plus:
#   **MailboxSettings.ReadWrite** — master category list
#   **Mail.ReadWrite** — read/PATCH messages for graph-tag-category
CANARY_MS_GRAPH_TENANT_ID=
CANARY_MS_GRAPH_CLIENT_ID=
CANARY_MS_GRAPH_CLIENT_SECRET=
# OWA base for compose deeplinks (default outlook.office.com/mail)
CANARY_OUTLOOK_WEB_MAIL_BASE=https://outlook.office.com/mail
# Category applied to new drafts (Exchange display name; create “Canary” in Outlook if missing)
CANARY_OUTLOOK_CATEGORY_NAME=Canary
# --- PostgreSQL ---
# Used by the `db` service and by the backend entrypoint to build DATABASE_URL (password is URL-encoded).
# The data volume stores the password from the *first* `docker compose up`; changing POSTGRES_PASSWORD
# later without recreating the volume causes auth errors — see comments in previous sections if needed.
POSTGRES_USER=canary
POSTGRES_PASSWORD=QQQQQQQQQQQQQQ
POSTGRES_DB=canary
# Optional: full URL; if set, POSTGRES_* above are not used to build DATABASE_URL for the backend.
# DATABASE_URL=postgresql+psycopg://canary:encodedpass@db:5432/canary
# Host publish: `host:container` or `ip:host:container`. Tighten on servers, e.g. 127.0.0.1:5432:5432
POSTGRES_PORT_PUBLISH=5432:5432
